# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://omnipos:omnipos@localhost:5432/omnipos_db

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another-long-random-string-for-refresh-tokens
JWT_REFRESH_EXPIRES_IN=30d

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ─── Dashboard ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
DASHBOARD_PORT=3001

# ─── Multi-tenancy ───────────────────────────────────────────────────────────
DEFAULT_TENANT_SLUG=default

# ─── Storage (future: S3-compatible for receipts / images) ───────────────────
# S3_BUCKET=omnipos-assets
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
